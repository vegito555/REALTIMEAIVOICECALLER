# ──────────────────────────────────────────────────────────────────────────────
# This file is for LOCAL DEVELOPMENT ONLY. In production (VPS / Coolify), real
# environment variables on the host are the single source of truth.
#
# To make the Python processes read this file, you must explicitly opt in:
#     export OUTBOUNDAI_LOAD_DOTENV=true
# Without that flag, .env is ignored — exactly as it will be in production.
# Even when enabled, .env values NEVER override variables already set on the
# host (load_dotenv is called with override=False).
#
# Note: OUTBOUNDAI_LOAD_DOTENV must be set in your shell BEFORE running the
# app (not inside this file), e.g. on Linux/macOS:
#   export OUTBOUNDAI_LOAD_DOTENV=true && bash start.sh
# ──────────────────────────────────────────────────────────────────────────────

# ── LiveKit Cloud ── cloud.livekit.io → Project → Keys
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ── Google Gemini ── aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key
GEMINI_MODEL=gemini-3.1-flash-live-preview
GEMINI_TTS_VOICE=Aoede
USE_GEMINI_REALTIME=true
GOOGLE_PROJECT_NUMBER=your_google_project_number

# ── Vobiz SIP telephony ── vobiz.ai
VOBIZ_SIP_DOMAIN=your-sip-domain.sip.vobiz.ai
VOBIZ_USERNAME=your_vobiz_username
VOBIZ_PASSWORD=your_vobiz_password
VOBIZ_OUTBOUND_NUMBER=+919876543210
OUTBOUND_TRUNK_ID=ST_xxxxxxxxxxxxxxxx
DEFAULT_TRANSFER_NUMBER=+919876543210

# ── Supabase ── supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PASSWORD=your_supabase_password
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ── S3 / Supabase Storage (call recordings — optional) ──
S3_ACCESS_KEY_ID=your_s3_access_key_id
S3_SECRET_ACCESS_KEY=your_s3_secret_access_key
S3_ENDPOINT_URL=https://your-project.supabase.co/storage/v1/s3
S3_REGION=ap-northeast-1
S3_BUCKET=call-recordings

# ── Cal.com (calendar booking sync — optional) ──
CALCOM_API_KEY=
CALCOM_EVENT_TYPE_ID=
CALCOM_TIMEZONE=Asia/Kolkata

# ── Twilio SMS (confirmation texts — optional) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Deepgram (pipeline fallback STT — optional) ──
DEEPGRAM_API_KEY=
